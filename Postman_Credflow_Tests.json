        {
          "name": "Criar usuário - Senha muito curta",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code é 400 (Bad Request)', function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Response contém erro sobre senha', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(JSON.stringify(jsonData)).to.include('password');",
                  "});"
                ]
